{
  "expo": {
    "name": "Saint Scale",
    "slug": "TCC",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "scheme": "tcc",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#7c2bff",
        "foregroundImage": "./src/assets/1.jpg",
        "backgroundImage": "./src/assets/1.jpg",
        "monochromeImage": "./src/assets/1.jpg"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.henzo.santos.TCC"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./src/assets/1.jpg"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./src/assets/1.jpg",
          "resizeMode": "contain",
          "backgroundColor": "#181529"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a473459c-afcf-4d11-8207-9fd0cfe1cd32"
      }
    }
  }
}
